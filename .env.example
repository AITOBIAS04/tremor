# TREMOR — Environment Configuration
# Copy to .env and fill in values

# =============================================================================
# OSINT Data Sources
# =============================================================================

# USGS real-time feeds (no auth required — public API)
USGS_FEED_BASE=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary
USGS_API_BASE=https://earthquake.usgs.gov/fdsnws/event/1

# EMSC (no auth required)
EMSC_API_BASE=https://seismicportal.eu/fdsnws/event/1

# IRIS DMC (no auth required)
IRIS_API_BASE=https://service.iris.edu/fdsnws/event/1

# =============================================================================
# Polling Configuration
# =============================================================================

# Default feed: m4.5_hour polls M4.5+ events from the last hour
# Options: significant_hour, m4.5_hour, m2.5_hour, m4.5_day, m2.5_day, all_hour, all_day
TREMOR_DEFAULT_FEED=m4.5_hour

# Poll interval in milliseconds (default: 60000 = 1 minute)
TREMOR_POLL_INTERVAL_MS=60000

# Enable cross-validation against EMSC/IRIS (requires network access)
TREMOR_CROSS_VALIDATION=false

# =============================================================================
# Echelon Framework
# =============================================================================

# Echelon Theatre registry endpoint (when available)
# ECHELON_REGISTRY_URL=

# Construct identity
TREMOR_CONSTRUCT_ID=tremor-v0.1.0

# =============================================================================
# Settlement Configuration
# =============================================================================

# Tier 2 provisional settlement: minimum age in seconds before auto accepted
TREMOR_PROVISIONAL_MIN_AGE_S=7200

# Tier 2: minimum quality composite for provisional settlement
TREMOR_PROVISIONAL_MIN_QUALITY=0.5

# Hard expiry: days after which unreviewed automatic events are treated as final
TREMOR_HARD_EXPIRY_DAYS=7

# Brier discount for provisional settlement (0-1)
TREMOR_PROVISIONAL_BRIER_DISCOUNT=0.10

# Brier discount for hard-expiry settlement (0-1)
TREMOR_HARD_EXPIRY_BRIER_DISCOUNT=0.25
